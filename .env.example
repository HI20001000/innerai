# MySQL connection settings
MYSQL_HOST=localhost
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=<YOUR_PASSWORD>
MYSQL_DATABASE=ai_platform
MYSQL_POOL_SIZE=10

# Prisma uses DATABASE_URL internally - auto built from MYSQL_* if unset
DATABASE_URL=mysql://root:<YOUR_PASSWORD>@localhost:3306/ai_platform

# API server configuration
PORT=3001
HOST=0.0.0.0
CORS_ALLOWED_ORIGINS=http://localhost:5173
REQUEST_BODY_LIMIT=10mb
JWT_SECRET=<YOUR_JWT_SECRET>
REGISTER_INVITE_TOKEN=<YOUR_REGISTER_TOKEN>

# Dify
DIFY_API_BASE_URL=<YOUR_DIFY_BASE_URL>
DIFY_API_KEY=<YOUR_DIFY_API_KEY>
DIFY_CHAT_ENDPOINT=/chat-messages
DIFY_TOKEN_LIMIT=32000
